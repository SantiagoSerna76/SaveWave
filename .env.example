# ============================================================
# VARIABLES DE ENTORNO - DescargarVideo
# ============================================================
# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio (esta en .gitignore).

# -------------------- SEGURIDAD --------------------
# Clave secreta para firmar cookies y tokens JWT
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-esta-clave-en-produccion
JWT_SECRET_KEY=cambiar-esta-clave-jwt
JWT_ACCESS_TOKEN_EXPIRES=3600

# -------------------- BASE DE DATOS (MySQL) --------------------
# Formato: mysql+pymysql://usuario:password@host:puerto/nombre_db
DATABASE_URL=mysql+pymysql://root:1107@localhost:3306/descargarvideo

# -------------------- STRIPE (PAGOS) --------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# -------------------- REDIS (TAREAS EN SEGUNDO PLANO) --------------------
REDIS_URL=redis://localhost:6379/0

# -------------------- ANUNCIOS --------------------
ADSENSE_CLIENT_ID=

# -------------------- SEGURIDAD AVANZADA --------------------
# Limite de peticiones por minuto a las APIs
RATELIMIT_DEFAULT=100 per minute
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# URL base del sitio (para enlaces en emails, etc.)
BASE_URL=http://localhost:5000