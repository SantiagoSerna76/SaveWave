# ============================================================
# VARIABLES DE ENTORNO - SaveWave
# ============================================================
# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio (esta en .gitignore).

# -------------------- SEGURIDAD --------------------
# Clave secreta para firmar cookies y tokens JWT
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-esta-clave-en-produccion
JWT_SECRET_KEY=cambiar-esta-clave-jwt
JWT_ACCESS_TOKEN_EXPIRES=3600

# -------------------- BASE DE DATOS (MySQL) --------------------
# Para desarrollo local: sqlite:///savewave.db
# Para produccion: mysql+pymysql://usuario:password@host:3306/savewave
DATABASE_URL=sqlite:///savewave.db

# -------------------- CACHE (Redis - opcional) --------------------
# Si Redis no esta disponible, se usa cache en memoria automaticamente
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TIMEOUT=900

# -------------------- STRIPE (PAGOS) --------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# -------------------- REDIS / CELERY (TAREAS EN SEGUNDO PLANO) --------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -------------------- INSTAGRAM LOGIN --------------------
# Necesario para descargar videos de Instagram
# Crea una cuenta dedicada (sin 2FA) para mejor estabilidad
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# -------------------- ANUNCIOS --------------------
ADSENSE_CLIENT_ID=

# -------------------- SEGURIDAD AVANZADA --------------------
# Limite de peticiones por minuto a las APIs
RATELIMIT_DEFAULT=100 per minute
RATELIMIT_STORAGE_URL=memory://

# URL base del sitio (para enlaces en emails, etc.)
BASE_URL=http://localhost:5000