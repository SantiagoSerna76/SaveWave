{
  "manifest_version": 3,
  "name": "SaveWave - Descarga videos y MP3",
  "version": "1.0.0",
  "description": "Descarga videos de YouTube, Instagram, TikTok, Facebook y cientos de plataformas mas. Tambien extrae audio a MP3.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://savewave.com/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "SaveWave",
  "homepage_url": "https://savewave.com"
}